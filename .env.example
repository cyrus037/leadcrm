# Database
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/lead-crm?retryWrites=true&w=majority"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-min-16-chars"

# Admin Credentials
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="your-secure-password"

# Resend API
RESEND_API_KEY="re_xxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxx"
EMAIL_TRACKING_ENABLED="false"

# Google Sheets
GOOGLE_SHEET_ID="your-sheet-id"
GOOGLE_SHEET_RANGE="Sheet1!A:E"
GOOGLE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID="your-project-id"

# Owner Email for Notifications
OWNER_EMAIL="growphonedigital@gmail.com"

# Application
APP_URL="http://localhost:3000"
# Production:
# NEXTAUTH_URL="https://lead.growphone.in"
# APP_URL="https://lead.growphone.in"

# Cron & Webhook Security
CRON_SECRET="your-cron-secret-min-16-chars"

# Optional: Redis for BullMQ (future scaling)
# REDIS_URL="redis://localhost:6379"
