generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  name          String?
  passwordHash  String?
  role          String    @default("admin")
  businessId    String?   @db.ObjectId
  business      Business? @relation(fields: [businessId], references: [id])
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  auditLogs     AuditLog[]

  @@index([businessId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id])
  sessionToken String   @unique
  expires      DateTime
  createdAt    DateTime @default(now())
}

model Lead {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  email           String          @unique
  name            String
  company         String?
  status          LeadStatus      @default(new)
  businessId      String?         @db.ObjectId
  business        Business?       @relation(fields: [businessId], references: [id])
  dateAdded       DateTime        @default(now())
  lastContacted   DateTime?
  notes           String?
  tags            String[]
  unsubscribed    Boolean         @default(false)
  bounced         Boolean         @default(false)
  timezone        String?
  engagementScore Float           @default(0)
  emailsSent      Int             @default(0)
  emailsOpened    Int             @default(0)
  emailsClicked   Int             @default(0)
  emailsReplied   Int             @default(0)
  activities      Activity[]
  emailLogs       EmailLog[]
  followupQueue   FollowupQueue[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([dateAdded])
  @@index([engagementScore])
  @@index([businessId])
}

model EmailLog {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  leadId          String            @db.ObjectId
  lead            Lead?             @relation(fields: [leadId], references: [id])
  templateId      String            @db.ObjectId
  template        Template          @relation(fields: [templateId], references: [id])
  businessId      String?           @db.ObjectId
  business        Business?         @relation(fields: [businessId], references: [id])
  type            EmailType
  status          EmailStatus       @default(pending)
  trackingToken   String?           @unique
  threadId        String?
  resendMessageId String?
  subject         String?
  sentAt          DateTime?
  error           String?
  retryCount      Int               @default(0)
  openCount       Int               @default(0)
  clickCount      Int               @default(0)
  firstOpenedAt   DateTime?
  lastOpenedAt    DateTime?
  repliedAt       DateTime?
  replyType       ReplyType?
  bouncedAt       DateTime?
  openEvents      EmailOpenEvent[]
  clickEvents     EmailClickEvent[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([leadId])
  @@index([status])
  @@index([sentAt])
  @@index([threadId])
  @@index([businessId])
}

model EmailOpenEvent {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  emailLogId String   @db.ObjectId
  emailLog   EmailLog @relation(fields: [emailLogId], references: [id])
  openedAt   DateTime @default(now())
  userAgent  String?
  ip         String?
  deviceType String?
  browser    String?
  location   String?

  @@index([emailLogId])
  @@index([openedAt])
}

model EmailClickEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  emailLogId  String   @db.ObjectId
  emailLog    EmailLog @relation(fields: [emailLogId], references: [id])
  originalUrl String
  clickedAt   DateTime @default(now())
  userAgent   String?
  ip          String?

  @@index([emailLogId])
  @@index([clickedAt])
}

model Template {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  type          TemplateType
  subject       String
  htmlContent   String
  variables     String[]
  isActive      Boolean         @default(true)
  businessId    String?         @db.ObjectId
  business      Business?       @relation(fields: [businessId], references: [id])
  emailLogs     EmailLog[]
  followupQueue FollowupQueue[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([type])
  @@index([isActive])
  @@index([businessId])
}

model Activity {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  leadId      String       @db.ObjectId
  lead        Lead         @relation(fields: [leadId], references: [id])
  businessId  String?      @db.ObjectId
  business    Business?    @relation(fields: [businessId], references: [id])
  type        ActivityType
  description String
  metadata    String?
  createdAt   DateTime     @default(now())

  @@index([leadId])
  @@index([createdAt])
  @@index([type])
  @@index([businessId])
}

model Settings {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId          String?  @unique @db.ObjectId
  business            Business @relation(fields: [businessId], references: [id])
  googleSheetId       String?
  googleSheetRange    String?
  resendApiKey        String?
  resendFromEmail     String?
  ownerEmail          String?
  followupDay1        Int      @default(7)
  followupDay2        Int      @default(14)
  emailRateLimit      Int      @default(2)
  emailDelayMs        Int      @default(5000)
  dailySendLimit      Int      @default(100)
  syncIntervalMinutes Int      @default(5)
  warmupEnabled       Boolean  @default(false)
  warmupDailyLimit    Int      @default(20)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model FollowupQueue {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  leadId       String         @db.ObjectId
  lead         Lead           @relation(fields: [leadId], references: [id])
  templateId   String         @db.ObjectId
  template     Template       @relation(fields: [templateId], references: [id])
  businessId   String?        @db.ObjectId
  business     Business?      @relation(fields: [businessId], references: [id])
  scheduledAt  DateTime
  status       FollowupStatus @default(pending)
  sequenceStep Int            @default(0)
  attemptCount Int            @default(0)
  lockedAt     DateTime?
  sentAt       DateTime?
  error        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([leadId])
  @@index([scheduledAt])
  @@index([status])
  @@index([leadId, status])
  @@index([businessId])
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String?  @db.ObjectId
  user       User?    @relation(fields: [userId], references: [id])
  businessId String?  @db.ObjectId
  business   Business? @relation(fields: [businessId], references: [id])
  action     String
  resource   String
  details    String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@index([businessId])
}

enum LeadStatus {
  new
  contacted
  followup1
  followup2
  replied
  interested
  closed
  ignored
}

enum EmailType {
  initial
  followup1
  followup2
  notification
  manual
}

enum EmailStatus {
  pending
  sent
  failed
  retrying
  bounced
  delivered
}

enum ReplyType {
  human
  out_of_office
  bounce
  spam_block
  unsubscribe
}

enum TemplateType {
  initial
  followup1
  followup2
  notification
}

enum ActivityType {
  status_change
  email_sent
  email_received
  email_opened
  email_clicked
  email_bounced
  note_added
  sync_completed
  followup_scheduled
  followup_sent
  followup_cancelled
  unsubscribed
}

enum FollowupStatus {
  pending
  processing
  sent
  failed
  cancelled
}

model Business {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  slug            String
  resendApiKey    String?
  resendFromEmail String?
  ownerEmail      String?
  isActive        Boolean  @default(true)
  users           User[]
  leads           Lead[]
  emailLogs       EmailLog[]
  templates       Template[]
  settings        Settings?
  followupQueue   FollowupQueue[]
  activities      Activity[]
  auditLogs       AuditLog[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([name])
  @@unique([slug])
  @@index([slug])
  @@index([isActive])
}
